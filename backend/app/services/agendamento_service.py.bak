from datetime import date, time
from typing import Sequence

from sqlalchemy import and_, func, select
from sqlalchemy.ext.asyncio import AsyncSession

from app.core.config import get_settings
from app.models.agendamento import Agendamento
from app.schemas.agendamento import (
    AgendamentoCreate,
    AgendamentoUpdate,
    DisponibilidadeOut,
    HorarioDisponivel,
)

settings = get_settings()

# ── Horários padrão do estabelecimento ───────────────────────────────────────
# Ajuste conforme o horário real da Iluminada Bronze
HORARIOS_FUNCIONAMENTO: list[time] = [
    time(8, 0),
    time(9, 0),
    time(10, 0),
    time(11, 0),
    time(12, 0),
    time(13, 0),
    time(14, 0),
    time(15, 0),
    time(16, 0),
    time(17, 0),
    time(18, 0),
]


async def criar_agendamento(db: AsyncSession, dados: AgendamentoCreate) -> Agendamento:
    """Cria um novo agendamento, respeitando o limite de vagas."""

    # 1. Verificar se o horário é válido
    if dados.horario_agendamento not in HORARIOS_FUNCIONAMENTO:
        raise ValueError("Horário inválido. Consulte os horários disponíveis.")

    # 2. Contar ocupação atual para aquele slot
    stmt_count = (
        select(func.count())
        .select_from(Agendamento)
        .where(
            and_(
                Agendamento.tipo_bronze == dados.tipo_bronze,
                Agendamento.data_agendamento == dados.data_agendamento,
                Agendamento.horario_agendamento == dados.horario_agendamento,
                Agendamento.status == "confirmado",
            )
        )
    )
    resultado = await db.execute(stmt_count)
    ocupacao = resultado.scalar_one()

    if ocupacao >= settings.MAX_VAGAS_POR_HORARIO:
        raise ValueError(
            f"Horário lotado! Máximo de {settings.MAX_VAGAS_POR_HORARIO} "
            "vagas já atingido para este horário."
        )

    # 3. Criar o agendamento
    novo = Agendamento(
        tipo_bronze=dados.tipo_bronze,
        data_agendamento=dados.data_agendamento,
        horario_agendamento=dados.horario_agendamento,
        cliente_nome=dados.cliente_nome.strip().title(),
        cliente_telefone=dados.cliente_telefone,
        cliente_cpf=dados.cliente_cpf,
        status="confirmado",
    )
    db.add(novo)
    await db.flush()   # gera o ID sem commitar
    await db.refresh(novo)
    return novo


async def listar_agendamentos(
    db: AsyncSession,
    tipo_bronze: str | None = None,
    data: date | None = None,
    status: str | None = None,
    limit: int = 100,
    offset: int = 0,
) -> Sequence[Agendamento]:
    """Lista agendamentos com filtros opcionais (uso do admin)."""
    stmt = select(Agendamento).order_by(
        Agendamento.data_agendamento, Agendamento.horario_agendamento
    )

    if tipo_bronze:
        stmt = stmt.where(Agendamento.tipo_bronze == tipo_bronze)
    if data:
        stmt = stmt.where(Agendamento.data_agendamento == data)
    if status:
        stmt = stmt.where(Agendamento.status == status)

    stmt = stmt.limit(limit).offset(offset)
    resultado = await db.execute(stmt)
    return resultado.scalars().all()


async def buscar_agendamento_por_id(db: AsyncSession, agendamento_id: str) -> Agendamento | None:
    resultado = await db.execute(
        select(Agendamento).where(Agendamento.id == agendamento_id)
    )
    return resultado.scalar_one_or_none()


async def atualizar_agendamento(
    db: AsyncSession, agendamento_id: str, dados: AgendamentoUpdate
) -> Agendamento:
    agendamento = await buscar_agendamento_por_id(db, agendamento_id)
    if not agendamento:
        raise ValueError("Agendamento não encontrado")

    update_data = dados.model_dump(exclude_unset=True)
    for campo, valor in update_data.items():
        setattr(agendamento, campo, valor)

    await db.flush()
    await db.refresh(agendamento)
    return agendamento


async def cancelar_agendamento(db: AsyncSession, agendamento_id: str) -> Agendamento:
    agendamento = await buscar_agendamento_por_id(db, agendamento_id)
    if not agendamento:
        raise ValueError("Agendamento não encontrado")
    agendamento.status = "cancelado"
    await db.flush()
    await db.refresh(agendamento)
    return agendamento


async def obter_disponibilidade(
    db: AsyncSession, tipo_bronze: str, data: date
) -> DisponibilidadeOut:
    """Retorna os horários e vagas disponíveis para um dia/serviço."""

    # Buscar ocupação atual de cada horário
    stmt = (
        select(
            Agendamento.horario_agendamento,
            func.count().label("total"),
        )
        .where(
            and_(
                Agendamento.tipo_bronze == tipo_bronze,
                Agendamento.data_agendamento == data,
                Agendamento.status == "confirmado",
            )
        )
        .group_by(Agendamento.horario_agendamento)
    )
    resultado = await db.execute(stmt)
    ocupacao_map: dict[time, int] = {
        row.horario_agendamento: row.total for row in resultado.all()
    }

    horarios = [
        HorarioDisponivel(
            horario=h,
            vagas_disponiveis=max(0, settings.MAX_VAGAS_POR_HORARIO - ocupacao_map.get(h, 0)),
            vagas_total=settings.MAX_VAGAS_POR_HORARIO,
        )
        for h in HORARIOS_FUNCIONAMENTO
    ]

    return DisponibilidadeOut(tipo_bronze=tipo_bronze, data=data, horarios=horarios)
