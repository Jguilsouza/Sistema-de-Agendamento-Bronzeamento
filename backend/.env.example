# ─────────────────────────────────────────────────────────────────────────────
# Copie este arquivo para .env e preencha com seus valores reais
# NUNCA commite o arquivo .env no Git!
# ─────────────────────────────────────────────────────────────────────────────

# ── Banco de dados ────────────────────────────────────────────────────────────
# Supabase:  postgresql+asyncpg://postgres.[ref]:[senha]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres
# Neon.tech: postgresql+asyncpg://[user]:[senha]@[host]/[db]?ssl=require
DATABASE_URL=postgresql+asyncpg://usuario:senha@host:5432/iluminada_bronze

# ── Segurança JWT ─────────────────────────────────────────────────────────────
# Gere uma chave segura com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=mude-essa-chave-para-producao
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Credenciais do administrador ──────────────────────────────────────────────
ADMIN_EMAIL=admin@iluminadabronze.com
ADMIN_PASSWORD=troque-esta-senha

# ── CORS – domínios permitidos ────────────────────────────────────────────────
# Em produção: liste apenas os domínios do seu frontend
# ALLOWED_ORIGINS=["https://seu-site.vercel.app","https://www.iluminadabronze.com.br"]
